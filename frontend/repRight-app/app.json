{
  "expo": {
    "name": "repRight-app",
    "slug": "repRight-app",
    "owner": "aaliyadesousa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "repright-app",
    "extra": {
      "googleClientId": "597817830458-07ognj6gmmljt7a2v62akc4j7bqiqjas.apps.googleusercontent.com",
      "androidClientId": "597817830458-nj9icr7gopkm2s14sr75kttsk2b6i0bf.apps.googleusercontent.com"
    },
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.repRightapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-vision-camera",
      
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "RepRight needs camera access to analyse your form in real time."
        }
      ],
      "expo-router",
      "expo-web-browser",
      "expo-font",
      "@react-native-google-signin/google-signin"
    ],
    
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
